<?xml version="1.0" encoding="UTF-8"?>
<addon id="plugin.video.mdm.flix"
       name="MDM Flix"
       version="0.0.11"
       provider-name="MDM">

    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
        <import addon="script.mdm.core" version="0.1.0"/>
    </requires>

    <extension point="xbmc.python.pluginsource"
               library="default.py">
        <provides>video</provides>
    </extension>

    <extension point="xbmc.addon.metadata">
        <summary>MDM Flix</summary>
        <description>Main video hub for the MDM Kodi ecosystem.</description>
        <platform>all</platform>
        <assets>
            <icon>icon.png</icon>
            <fanart>fanart.jpg</fanart>
        </assets>
    </extension>
</addon>